---
const linkedinUrl = "https://www.linkedin.com/in/evanluputra/";
---
<nav class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-gray-100">
  <div class="max-w-7xl mx-auto px-5 sm:px-10 py-4 sm:py-6 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="font-medium text-lg text-primary shrink-0 transition-opacity duration-200 hover:opacity-70">
      Evan Luputra
    </a>

    <!-- Desktop Nav -->
    <div class="hidden md:flex items-center gap-6 lg:gap-8">
      <a href="#projects" class="text-sm text-[#020202] hover:text-primary transition-colors link-underline">Projects</a>
      <a href="/about" class="text-sm text-[#020202] hover:text-primary transition-colors link-underline">About</a>
      <a href="/design-process" class="text-sm text-[#020202] hover:text-primary transition-colors link-underline">Design Process</a>
      <a href="#resume" class="text-sm text-[#020202] hover:text-primary transition-colors link-underline">Resume</a>
      <a href={linkedinUrl} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="hover:opacity-70 transition-all duration-200 hover:scale-110 inline-block">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M3.14 14H0.23V4.65H3.14V14ZM1.68 3.37C0.75 3.37 0 2.6 0 1.67C0 0.74 0.75 0 1.68 0C2.61 0 3.36 0.74 3.36 1.67C3.36 2.6 2.61 3.37 1.68 3.37ZM14 14H11.09V9.45C11.09 8.37 11.07 6.99 9.6 6.99C8.11 6.99 7.88 8.17 7.88 9.37V14H4.97V4.65H7.76V5.93H7.8C8.19 5.19 9.16 4.41 10.6 4.41C13.55 4.41 14 6.35 14 8.87V14Z" fill="#020202"/>
        </svg>
      </a>
    </div>

    <!-- Mobile hamburger -->
    <button id="menu-btn" class="md:hidden p-2 rounded-md hover:bg-gray-100 transition-all duration-200 active:scale-90" aria-label="Toggle menu" aria-expanded="false">
      <svg id="icon-open" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M2 5H18M2 10H18M2 15H18" stroke="#020202" stroke-width="2" stroke-linecap="round"/>
      </svg>
      <svg id="icon-close" class="hidden" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M4 4L16 16M16 4L4 16" stroke="#020202" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-gray-100">
    <div class="px-5 py-4 flex flex-col gap-4">
      <a href="#projects" class="text-sm text-[#020202] hover:text-primary transition-colors link-underline w-fit">Projects</a>
      <a href="#about" class="text-sm text-[#020202] hover:text-primary transition-colors link-underline w-fit">About</a>
      <a href="#services" class="text-sm text-[#020202] hover:text-primary transition-colors link-underline w-fit">Design Process</a>
      <a href="#resume" class="text-sm text-[#020202] hover:text-primary transition-colors link-underline w-fit">Resume</a>
      <a href={linkedinUrl} target="_blank" rel="noopener noreferrer" class="text-sm text-[#020202] hover:text-primary transition-colors flex items-center gap-2 w-fit link-underline">
        LinkedIn ↗
      </a>
    </div>
  </div>
</nav>

<script>
  const menuBtn = document.getElementById('menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  menuBtn?.addEventListener('click', () => {
    const isOpen = !mobileMenu?.classList.contains('hidden');
    if (isOpen) {
      mobileMenu?.classList.add('hidden');
      mobileMenu?.classList.remove('menu-open');
    } else {
      mobileMenu?.classList.remove('hidden');
      // trigger reflow so animation replays
      void (mobileMenu as HTMLElement).offsetWidth;
      mobileMenu?.classList.add('menu-open');
    }
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
    menuBtn?.setAttribute('aria-expanded', String(!isOpen));
  });

  function closeMobileMenu() {
    mobileMenu?.classList.add('hidden');
    mobileMenu?.classList.remove('menu-open');
    iconOpen?.classList.remove('hidden');
    iconClose?.classList.add('hidden');
    menuBtn?.setAttribute('aria-expanded', 'false');
  }

  // Smooth scroll for all anchor links
  document.querySelectorAll('a[href^="#"]').forEach(link => {
    link.addEventListener('click', (e) => {
      const href = link.getAttribute('href');
      if (!href || href === '#') return;
      const target = document.querySelector(href);
      if (target) {
        e.preventDefault();
        const navHeight = document.querySelector('nav')?.offsetHeight ?? 80;
        const top = target.getBoundingClientRect().top + window.scrollY - navHeight;
        window.scrollTo({ top, behavior: 'smooth' });
      }
    });
  });

  // Close mobile menu on link click
  document.querySelectorAll('#mobile-menu a').forEach(link => {
    link.addEventListener('click', closeMobileMenu);
  });
</script>
