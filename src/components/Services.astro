---
const services = [
  {
    title: "UX Design",
    description: "Improve customer satisfaction and loyalty through ease of use and pleasure provided in the interaction with a product.",
    icon: "https://www.figma.com/api/mcp/asset/824c568e-4a83-4b94-b204-38ae9785c0cb",
  },
  {
    title: "Interaction Design",
    description: "Create engaging interfaces and understand how users and technology communicate with each other.",
    icon: "https://www.figma.com/api/mcp/asset/eaf93ba0-adc2-4ec8-b5c2-6281d6af57ac",
  },
  {
    title: "Business-focused Goals",
    description: "Try to align UX strategy with business goals by identifying the good approach that benefits users, partners, and company.",
    icon: "https://www.figma.com/api/mcp/asset/64a83770-5a97-4be2-a3e2-7baeefef046c",
  },
  {
    title: "Design System",
    description: "Create the master component, apply design token, and implement the accessibility to it.",
    icon: "https://www.figma.com/api/mcp/asset/d55f674c-e3fd-4379-8269-2f64c0e0be25",
  },
  {
    title: "AI-Design Approach",
    description: "Design for autonomous AI agents that perform multi-step tasks, such as booking the trip or generating the trip ideas.",
    icon: "https://www.figma.com/api/mcp/asset/d55f674c-e3fd-4379-8269-2f64c0e0be25",
  },
  {
    title: "Agile Team Collaboration",
    description: "Collaborate with variety of teams, including marketers, developers, and PMs to create products that customer and company need.",
    icon: "https://www.figma.com/api/mcp/asset/d55f674c-e3fd-4379-8269-2f64c0e0be25",
  },
  {
    title: "Product Discovery",
    description: "Learn from the user's feedback, and apply that information to create great products with a higher potential for success in the marketplace.",
    icon: "https://www.figma.com/api/mcp/asset/eaf93ba0-adc2-4ec8-b5c2-6281d6af57ac",
  },
];
---

<section
  id="services"
  class="relative px-5 sm:px-10 lg:px-20 py-16 lg:py-20 overflow-hidden"
  style={{ background: "linear-gradient(119deg, #34495e 6.78%, #2c3e50 87.8%)" }}
>
  <div class="max-w-7xl mx-auto">
    <h2 class="font-semibold text-white text-xl sm:text-2xl text-center mb-10 lg:mb-14">
      My Services
    </h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-10">
      {services.map(service => (
        <div class="flex flex-col gap-3 p-4 rounded-xl card-lift cursor-default hover:bg-white/5">
          <div class="w-8 h-8 relative shrink-0 icon-spin">
            <img src={service.icon} alt="" class="w-full h-full object-contain" loading="lazy" />
          </div>
          <h3 class="font-medium text-white text-lg sm:text-xl leading-normal">{service.title}</h3>
          <p class="font-normal text-white/90 text-sm sm:text-base leading-relaxed">{service.description}</p>
        </div>
      ))}
    </div>

    <!-- CTA Button -->
    <div class="flex justify-center mt-12 lg:mt-16">
      <a
        href="#contact"
        class="btn-press inline-block bg-white text-[#020202] font-medium text-sm sm:text-base px-6 py-3 rounded-md hover:bg-gray-100 transition-all duration-200 hover:shadow-lg hover:-translate-y-0.5"
      >
        Let's work together
      </a>
    </div>
  </div>
</section>
